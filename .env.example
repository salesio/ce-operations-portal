# -----------------------------------------------------------------------
# CE Mozambique Operations Dashboard — environment example
# Copy to .env and fill in values. Never commit .env with real secrets.
# -----------------------------------------------------------------------

# --- Data source flag (browser data layer) ---
# mock     = in-memory sample provider (default; safe, no UI migration)
# local    = isolated localStorage keys (ce-data-layer:*) for prototypes
# api      = future HTTP backend → PostgreSQL (placeholder only for now)
# supabase = future Supabase repositories (placeholder; finance bridge separate)
# Keep mock or local until Backend Phase 2+ pilots are ready.
VITE_DATA_SOURCE=local

# --- App environment (frontend label only) ---
VITE_APP_ENV=development

# --- Feature flags (all OFF by default — safe for GitHub Pages / local dev) ---
VITE_ENABLE_SUPABASE=false
VITE_ENABLE_REAL_AUTH=false
VITE_ENABLE_STORAGE=false
VITE_ENABLE_RLS=false

# --- Supabase public client (browser-safe anon key only) ---
# Used only when VITE_ENABLE_SUPABASE=true AND VITE_DATA_SOURCE=supabase (future pilots).
# NEVER put service role key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- API mode (future Node/Express or Edge API) ---
# Used only when VITE_DATA_SOURCE=api. Leave empty for mock/local.
VITE_API_BASE_URL=

# -----------------------------------------------------------------------
# BACKEND-ONLY — DO NOT import in frontend / Vite client code
# Never expose these via VITE_* or commit real production secrets.
# -----------------------------------------------------------------------

# Local PostgreSQL (Docker Compose / future self-hosted DB)
POSTGRES_DB=ce_dashboard
POSTGRES_USER=ce_admin
POSTGRES_PASSWORD=ce_dev_password

# Host machine → Postgres published on localhost:5433
DATABASE_URL=postgresql://ce_admin:ce_dev_password@localhost:5433/ce_dashboard

# Containers → Postgres service hostname on the Docker network
DATABASE_URL_DOCKER=postgresql://ce_admin:ce_dev_password@postgres:5432/ce_dashboard

# Supabase service role — server/CI/migrations ONLY.
# NEVER ship this to the browser. NEVER prefix with VITE_.
SUPABASE_SERVICE_ROLE_KEY=
